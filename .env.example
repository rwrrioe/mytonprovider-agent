DB_PORT=5432
DB_USER=pguser
DB_PASSWORD=secret
DB_NAME=providerdb

# Redis
REDIS_ADDR=redis:6379
REDIS_PASSWORD=
REDIS_DB=0

# System (если пусто — генерируется на старте)
SYSTEM_KEY=
AGENT_ID=auto
